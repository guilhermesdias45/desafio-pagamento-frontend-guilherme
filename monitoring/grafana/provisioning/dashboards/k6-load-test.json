{
  "uid": "k6-load-test",
  "title": "k6 Load Testing — Acabou o Mony",
  "tags": ["k6", "load-test", "performance"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "5s",
  "time": { "from": "now-30m", "to": "now" },
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "panels": [
    {
      "id": 1,
      "title": "VUs ativos",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 10 }
            ]
          },
          "unit": "none"
        }
      },
      "targets": [
        {
          "expr": "k6_vus",
          "legendFormat": "VUs",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Taxa de requisições",
      "type": "stat",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          },
          "unit": "reqps"
        }
      },
      "targets": [
        {
          "expr": "rate(k6_http_reqs_total[1m])",
          "legendFormat": "req/s",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Taxa de erro",
      "type": "stat",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          },
          "unit": "percentunit",
          "max": 1
        }
      },
      "targets": [
        {
          "expr": "rate(k6_http_req_failed_total[1m]) / rate(k6_http_reqs_total[1m])",
          "legendFormat": "error rate",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Latência P99",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 700 },
              { "color": "red", "value": 1000 }
            ]
          },
          "unit": "ms"
        }
      },
      "targets": [
        {
          "expr": "k6_http_req_duration_p99 * 1000",
          "legendFormat": "P99",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Total de requisições",
      "type": "stat",
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "blue" },
          "unit": "none"
        }
      },
      "targets": [
        {
          "expr": "k6_http_reqs_total",
          "legendFormat": "total",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "Iterações concluídas",
      "type": "stat",
      "gridPos": { "x": 20, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "green" },
          "unit": "none"
        }
      },
      "targets": [
        {
          "expr": "k6_iterations_total",
          "legendFormat": "iterações",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "title": "Latência por percentil (ms)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 16, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "lineWidth": 2, "fillOpacity": 5 }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "P99" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "P95" }, "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "P90" }, "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "P50" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] }
        ]
      },
      "targets": [
        { "expr": "k6_http_req_duration_p99 * 1000",  "legendFormat": "P99",  "refId": "A" },
        { "expr": "k6_http_req_duration_p95 * 1000",  "legendFormat": "P95",  "refId": "B" },
        { "expr": "k6_http_req_duration_p90 * 1000",  "legendFormat": "P90",  "refId": "C" },
        { "expr": "k6_http_req_duration_p50 * 1000",  "legendFormat": "P50",  "refId": "D" }
      ]
    },
    {
      "id": 8,
      "title": "Virtual Users ao longo do tempo",
      "type": "timeseries",
      "gridPos": { "x": 16, "y": 4, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "custom": { "lineWidth": 2, "fillOpacity": 20 },
          "color": { "fixedColor": "blue", "mode": "fixed" }
        }
      },
      "targets": [
        { "expr": "k6_vus", "legendFormat": "VUs ativos", "refId": "A" },
        { "expr": "k6_vus_max", "legendFormat": "VUs máx configurados", "refId": "B" }
      ]
    },
    {
      "id": 9,
      "title": "Throughput — requisições/s",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "targets": [
        { "expr": "rate(k6_http_reqs_total[30s])",        "legendFormat": "total req/s",   "refId": "A" },
        { "expr": "rate(k6_http_req_failed_total[30s])",  "legendFormat": "erros/s",        "refId": "B" }
      ]
    },
    {
      "id": 10,
      "title": "Breakdown de latência (transferência, espera, conexão)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "lineWidth": 1, "fillOpacity": 5 }
        }
      },
      "targets": [
        { "expr": "k6_http_req_waiting_p95 * 1000",     "legendFormat": "waiting P95",     "refId": "A" },
        { "expr": "k6_http_req_sending_p95 * 1000",     "legendFormat": "sending P95",     "refId": "B" },
        { "expr": "k6_http_req_receiving_p95 * 1000",   "legendFormat": "receiving P95",   "refId": "C" },
        { "expr": "k6_http_req_connecting_p95 * 1000",  "legendFormat": "connecting P95",  "refId": "D" }
      ]
    }
  ]
}
