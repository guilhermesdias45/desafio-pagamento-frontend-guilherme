# =============================================================================
# Acabou o Mony — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores antes de rodar o projeto
# NUNCA commite o .env com valores reais
# =============================================================================

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=aom
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_PORT=5432

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_STRONG_PASSWORD
REDIS_PORT=6379

# ─── Kafka ────────────────────────────────────────────────────────────────────
# Porta exposta no host (containers internos usam kafka:9092)
KAFKA_PORT=9094

# ─── JWT RS256 ────────────────────────────────────────────────────────────────
# Gerar chave privada: openssl genrsa -out private.pem 2048
# Gerar chave pública: openssl rsa -in private.pem -pubout -out public.pem
# Converter para linha única: awk 'NF {sub(/\r/, ""); printf "%s\\n",$0;}' private.pem
JWT_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\nCHANGE_ME\n-----END RSA PRIVATE KEY-----
JWT_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\nCHANGE_ME\n-----END PUBLIC KEY-----

# ─── Criptografia AES-256 (secret TOTP em repouso) ───────────────────────────
# Gerar: openssl rand -hex 32
TOTP_AES_KEY=CHANGE_ME_64_CHAR_HEX_STRING

# ─── Endpoint interno (user-service ↔ api-gateway) ──────────────────────────
INTERNAL_SECRET=CHANGE_ME_STRONG_RANDOM_STRING

# ─── TOTP / 2FA ─────────────────────────────────────────────────────────────
TOTP_ISSUER=AcabouoMony

# ─── Mercado Pago ─────────────────────────────────────────────────────────────
# Sandbox: https://www.mercadopago.com.br/developers/pt/docs/checkout-api/integration-test
MERCADOPAGO_ACCESS_TOKEN=TEST-CHANGE_ME
MERCADOPAGO_ENCRYPTION_KEY=965d2fd56e120abbae2deded7821deb208cee3ffd9bc7016f084cb513c1fbdc0
MP_CLIENT_ID=6025083406574896
MP_CLIENT_SECRET=zjeRbKLaS6fzhu8mFBxIHoihhUm1UqDe

# ─── Email (SMTP) ─────────────────────────────────────────────────────────────
# Para desenvolvimento: usar Mailtrap (https://mailtrap.io) ou Gmail App Password
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=seu-email@gmail.com
MAIL_PASSWORD=sua-app-password-gmail

# ─── New Relic ────────────────────────────────────────────────────────────────
# https://one.newrelic.com → Account Settings → API Keys → License Key
# A License Key é usada tanto para o agente Java quanto para o Micrometer registry (api-key)
NEW_RELIC_LICENSE_KEY=CHANGE_ME
# https://one.newrelic.com → Account Settings → Account ID (número no canto superior direito)
NEW_RELIC_ACCOUNT_ID=CHANGE_ME
# Habilitar exportação de métricas para o New Relic (false em dev, true em produção)
NEW_RELIC_ENABLED=false
# Ambiente (local | staging | production) — aparece como tag em todas as métricas
APP_ENV=development

# ─── Grafana ──────────────────────────────────────────────────────────────────
# Acesse em http://localhost:3000 (usuário: admin)
# Iniciar: docker compose --profile monitoring up -d
GRAFANA_PASSWORD=admin

# ─── Anthropic (Claude AI — fraud-service) ───────────────────────────────────
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=CHANGE_ME
